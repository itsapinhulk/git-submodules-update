#!/usr/bin/env bash
# Create and push a release tag.
# Usage: scripts/release <version>
# Example: scripts/release v1.2
set -euo pipefail

if [[ $# -ne 1 ]]; then
    echo "Usage: scripts/release <version>" >&2
    echo "Example: scripts/release v1.2" >&2
    exit 1
fi

VERSION="$1"

# Normalise: accept both "1.2" and "v1.2"
if [[ "$VERSION" != v* ]]; then
    VERSION="v${VERSION}"
fi

# Validate vMAJOR.PATCH
if ! [[ "$VERSION" =~ ^v[0-9]+\.[0-9]+$ ]]; then
    echo "Error: version must be in the form vMAJOR.PATCH (e.g. v1.2)" >&2
    exit 1
fi

# Must be on a clean working tree
if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "Error: working tree is not clean — commit or stash changes first." >&2
    exit 1
fi

echo "Tagging $VERSION ..."
git tag -a "$VERSION" -m "Release $VERSION"

MAJOR=$(echo "$VERSION" | grep -oE '^v[0-9]+')

echo "Pushing $VERSION ..."
git push origin "$VERSION"

echo "Updating floating major tag $MAJOR ..."
git tag -f "$MAJOR"
git push origin "$MAJOR" --force

echo "Done. GitHub Actions will create the release from the tag."
