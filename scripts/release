#!/usr/bin/env bash
# Create and push a release tag for the version in the VERSION file.
# Usage: scripts/release [-y]
set -euo pipefail

YES=false
while [[ $# -gt 0 ]]; do
    case "$1" in
        -y|--yes) YES=true; shift ;;
        *) echo "Usage: scripts/release [-y|--yes]" >&2; exit 1 ;;
    esac
done

REPO_ROOT="$(git rev-parse --show-toplevel)"
VERSION_FILE="$REPO_ROOT/VERSION"

if [[ ! -f "$VERSION_FILE" ]]; then
    echo "Error: VERSION file not found at $VERSION_FILE" >&2
    exit 1
fi

VERSION="$(cat "$VERSION_FILE" | tr -d '[:space:]')"

# Validate vMAJOR.PATCH
if ! [[ "$VERSION" =~ ^v[0-9]+\.[0-9]+$ ]]; then
    echo "Error: VERSION file contains invalid version '$VERSION' (expected vMAJOR.PATCH)" >&2
    exit 1
fi

# Must be on a clean working tree
if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "Error: working tree is not clean — commit or stash changes first." >&2
    exit 1
fi

echo "Fetching tags ..."
git fetch --tags

# Verify the tag doesn't already exist
if git tag | grep -qx "$VERSION"; then
    echo "Error: tag $VERSION already exists." >&2
    exit 1
fi

if [[ "$YES" != true ]]; then
    read -r -p "Release $VERSION? [y/N] " confirm
    if [[ "$confirm" != [yY] ]]; then
        echo "Aborted." >&2
        exit 1
    fi
fi

echo "Tagging $VERSION ..."
git tag -a "$VERSION" -m "Release $VERSION"

MAJOR=$(echo "$VERSION" | grep -oE '^v[0-9]+')

echo "Pushing $VERSION ..."
git push origin "$VERSION"

echo "Updating floating major tag $MAJOR ..."
git tag -f "$MAJOR"
git push origin "$MAJOR" --force

RELEASE_BRANCH="release-$MAJOR"
echo "Updating release branch $RELEASE_BRANCH ..."
git push origin "HEAD:refs/heads/$RELEASE_BRANCH" --force

echo "Done. GitHub Actions will create the release from the tag."
